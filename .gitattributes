# Default: text files autodetect, but binary files без преобразований.
* text=auto

# Shell scripts ВСЕГДА LF — иначе на Linux ломается shebang
# (`bash: /bin/bash^M: bad interpreter`). Critical для Эльбрус-сборки.
*.sh           text eol=lf
*.bash         text eol=lf
scripts/**     text eol=lf

# Source code — LF (стандарт)
*.c            text eol=lf
*.cpp          text eol=lf
*.h            text eol=lf
*.hpp          text eol=lf
*.cu           text eol=lf
*.cuh          text eol=lf
*.cmake        text eol=lf
CMakeLists.txt text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.md           text eol=lf

# Windows-specific — CRLF
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf

# Бинарники — без преобразований
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.pdf          binary
*.zip          binary
*.tar          binary
*.gz           binary
*.gguf         binary
*.bin          binary
*.ckpt         binary
*.pt           binary
*.so           binary
*.dll          binary
*.exe          binary
*.lib          binary
*.dylib        binary
